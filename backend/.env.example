PORT=5000

DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_SERVER=your_database_host
DB_NAME=your_database_name
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# Render managed PostgreSQL should use these values.
DB_DRIVER=postgres
DATABASE_URL=postgresql://user:password@host:5432/database
PGSSLMODE=require

JWT_SECRET=change_this_to_a_long_random_secret
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
MAIL_FROM=your_verified_sender@example.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=
ENCRYPTION_KEY=change_this_to_a_long_random_encryption_key

FRONTEND_URL=http://localhost:5173,https://secure-web-app-teal.vercel.app
UPLOADS_DIR=./uploads

# Optional one-time bootstrap login for fresh production databases.
BOOTSTRAP_USER_EMAIL=
BOOTSTRAP_USER_PASSWORD=
BOOTSTRAP_USER_FULL_NAME=AuthGuard Admin
BOOTSTRAP_USER_ROLE=admin
